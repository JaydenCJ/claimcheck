{
  "name": "claimcheck",
  "version": "0.1.0",
  "description": "Audits npm, pip and Maven configs for dependency-confusion exposure — unscoped internals, missing registry mappings — statically, offline, no probing.",
  "author": "JaydenCJ <aisingioro.kiyon@gmail.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "claimcheck": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"tests/*.test.mjs\"",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [
    "dependency-confusion",
    "supply-chain",
    "npm",
    "pip",
    "maven",
    "registry",
    "audit",
    "security"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaydenCJ/claimcheck.git"
  },
  "homepage": "https://github.com/JaydenCJ/claimcheck#readme",
  "bugs": {
    "url": "https://github.com/JaydenCJ/claimcheck/issues"
  }
}
